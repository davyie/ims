# =============================================================================
# Root — repo-level ignores
# Subdirectory-specific rules live in backend/.gitignore
# and frontend/ims-frontend/.gitignore
# =============================================================================

# Environment secrets — never commit the real .env
.env
.env.*
!.env.example

# =============================================================================
# Docker
# =============================================================================

# Override files used for local tweaks
docker-compose.override.yml
docker-compose.local.yml

# =============================================================================
# OS
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
*.icloud
Icon

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# IDEs
# =============================================================================

# IntelliJ IDEA (root-level project files)
.idea/
*.iml

# VS Code (keep shared settings)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# =============================================================================
# Logs
# =============================================================================

*.log
logs/
