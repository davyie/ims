# =============================================================================
# Frontend — Angular 18 / Node.js / TypeScript
# =============================================================================

# Build output
/dist/
/tmp/
/out-tsc/
/bazel-out/

# Dependencies
/node_modules/

# Angular CLI cache
/.angular/
/.angular/cache/

# Sass cache
.sass-cache/

# TypeScript incremental build info
*.tsbuildinfo
tsconfig.tsbuildinfo

# Test output
/coverage/
/test-results/
*.lcov
junit.xml

# =============================================================================
# Runtime / debug
# =============================================================================

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/connect.lock
/libpeerconnection.log
testem.log
/typings

# =============================================================================
# Environment — never commit real secrets
# =============================================================================

src/environments/environment.prod.ts
src/environments/environment.local.ts
.env
.env.*
!.env.example

# =============================================================================
# IDEs
# =============================================================================

# IntelliJ / WebStorm
.idea/
*.iml

# VS Code (keep shared settings, ignore personal/local overrides)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# Eclipse
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# =============================================================================
# OS
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

