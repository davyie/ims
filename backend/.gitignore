# =============================================================================
# Backend — Java 21 / Spring Boot / Maven
# =============================================================================

# Maven build output
target/
*/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
pom.xml.bak
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# Maven wrapper binary (use the script, not the jar)
.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties

# Compiled class files
*.class

# Package / archive files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Logs
*.log
logs/
log/

# Spring Boot dev tools restart trigger
.spring-boot-devtools.properties
spring-devtools.properties

# Application secrets — never commit real values
application-prod.properties
application-prod.yml
*.env
secrets/

# JVM crash logs
hs_err_pid*
replay_pid*

# Test reports
surefire-reports/
failsafe-reports/

# Code coverage
jacoco.exec
*.exec

