# =============================================================================
# IMS Environment Configuration — EXAMPLE
# Copy this file to .env and fill in the values.
# This file IS committed to version control (no real secrets).
# =============================================================================

# -----------------------------------------------------------------------------
# Production (docker-compose.yml)
# -----------------------------------------------------------------------------

SPRING_PROFILES_ACTIVE=prod

# Postgres
POSTGRES_DB=imsdb
POSTGRES_USER=ims
POSTGRES_PASSWORD=changeme

# App → Postgres connection
DB_HOST=postgres
DB_PORT=5432
DB_NAME=imsdb
DB_USERNAME=ims
DB_PASSWORD=changeme

# Kafka
KAFKA_BOOTSTRAP=kafka-1f7fdcb6-davyie-dev.k.aivencloud.com:13875

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=changeme_replace_with_a_long_random_base64_string
JWT_EXPIRATION_MS=86400000

# Docker images
APP_IMAGE=application:1.0.0
FRONTEND_IMAGE=frontend:1.0.0

# Exposed ports
APP_PORT=8080
FRONTEND_PORT=80

# Nginx upstream — must match the backend Docker service name
API_URL=http://application:8080

# Outbox poller interval (ms)
OUTBOX_POLL_MS=500

# Log level override (optional)
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Test (docker-compose.test.yml)
# -----------------------------------------------------------------------------

TEST_SPRING_PROFILES_ACTIVE=test

# Postgres (test)
TEST_POSTGRES_DB=imsdb_test
TEST_POSTGRES_USER=ims
TEST_POSTGRES_PASSWORD=changeme

# App → Postgres (test)
TEST_DB_HOST=postgres-test
TEST_DB_PORT=5432
TEST_DB_NAME=imsdb_test
TEST_DB_USERNAME=ims
TEST_DB_PASSWORD=changeme

# Exposed ports (test — offset to avoid clashing with prod)
TEST_APP_PORT=8081
TEST_FRONTEND_PORT=8082
TEST_DB_HOST_PORT=5433

# Nginx upstream (test — must match the test backend service name)
TEST_API_URL=http://application-test:8080
